# Copy this to .env and adjust if needed.
# Every service reads these so there is ONE place to change config.

KAFKA_BOOTSTRAP=kafka:9092        # Kafka broker address (inside docker network)
RTSP_URL=rtsp://mediamtx:8554/cam1 # The simulated camera the ingest worker pulls from
CAMERA_ID=cam1                     # Logical camera name; rides on every message
FRAME_WIDTH=640                    # Downscale frames to this width before publishing
TARGET_FPS=10                      # Throttle ingest; CPU-friendly starting point
MODEL_NAME=yolo26n.pt              # Nano variant = CPU-viable
CONF_THRESHOLD=0.35                # Detections below this confidence are dropped
